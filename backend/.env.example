# Variables de entorno - Backend Gestióncredifacil (Vercel + Supabase)

# Database (Supabase)
DATABASE_URL="postgresql://user:password@your-supabase-host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@your-supabase-host:5432/postgres"

# JWT Secrets (Cambiar en producción por valores seguros)
JWT_SECRET="tu-super-secreto-jwt-cambiar-en-produccion"
JWT_REFRESH_SECRET="tu-super-secreto-refresh-cambiar-en-produccion"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Frontend URL (para CORS) — Tu dominio de Vercel
# Ejemplo: https://gestioncredifacil.vercel.app
FRONTEND_URL=""

# Email Service (Resend)
RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM="noreply@gestioncredifacil.com"

# Environment
NODE_ENV="development"
PORT=3000
